---
import "../styles/global.css";
import { sitePath } from "../lib/catalog";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Robi Gadget Shop",
  description = "Robi Gadget Shop catalog for mobile phones, smartwatches, and bluetooth headphones in Bangladesh.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <div class="topbar-inner">
          <a class="brand" href={sitePath("/")}>
            <img class="brand-logo" src={sitePath("/images/logo.webp")} alt="Robi Gadget Shop" />
            <span>Robi Gadget Shop</span>
          </a>
          <nav class="nav" aria-label="Main navigation">
            <a href={sitePath("/category/mobile-phone/")}>Mobiles</a>
            <a href={sitePath("/category/smartwatch/")}>Watches</a>
            <a href={sitePath("/category/bluetooth-headphone/")}>Audio</a>
            <a href={sitePath("/tag/5g/")}>5G Deals</a>
          </nav>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="footer">
        <div class="footer-inner">
          <div class="footer-brand">
            <a class="brand" href={sitePath("/")}>
              <img class="brand-logo footer-logo" src={sitePath("/images/logo.webp")} alt="Robi Gadget Shop" />
              <span>Robi Gadget Shop</span>
            </a>
            <p>
              A static gadget storefront for mobile phones, smartwatches, and bluetooth audio in Bangladesh.
            </p>
          </div>
          <div class="footer-links">
            <div>
              <h2>Shop</h2>
              <a href={sitePath("/category/mobile-phone/")}>Mobile phones</a>
              <a href={sitePath("/category/smartwatch/")}>Smartwatches</a>
              <a href={sitePath("/category/bluetooth-headphone/")}>Bluetooth audio</a>
            </div>
            <div>
              <h2>Explore</h2>
              <a href={sitePath("/category/flagship/")}>Flagship</a>
              <a href={sitePath("/tag/5g/")}>5G</a>
              <a href={sitePath("/tag/anc/")}>ANC audio</a>
            </div>
            <div>
              <h2>Store</h2>
              <span>Dhaka, Bangladesh</span>
              <span>Price sync planned from vendor API</span>
              <span>No checkout enabled</span>
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <span>© 2026 Robi Gadget Shop</span>
          <span>Static catalog powered by Astro and GitHub Pages</span>
        </div>
      </footer>
    </div>
  </body>
</html>
