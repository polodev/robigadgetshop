---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import products from "../../content/products.json";
import { collectionCount, labelize } from "../../lib/catalog";

export function getStaticPaths() {
  const categories = Array.from(new Set(products.flatMap((product) => product.category)));
  return categories.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const matchingProducts = products.filter((product) => product.category.includes(slug));
const relatedTags = Object.entries(collectionCount(matchingProducts.flatMap((product) => product.tags)))
  .sort((a, b) => b[1] - a[1])
  .slice(0, 16);
---

<BaseLayout
  title={`${labelize(slug)} Products | Robi Gadget Shop`}
  description={`Browse ${labelize(slug)} products from Robi Gadget Shop in Bangladesh.`}
>
  <section class="collection-hero">
    <div class="container collection-hero-inner">
      <div>
        <span class="product-meta">Category</span>
        <h1>{labelize(slug)}</h1>
        <p>{matchingProducts.length} products available in this collection.</p>
      </div>
      <div class="filter-links">
        {relatedTags.map(([tag, count]) => (
          <a href={`/tag/${tag}/`}>#{tag} <span>{count}</span></a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="product-grid">
        {matchingProducts.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>
</BaseLayout>
